root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
trim_trailing_whitespace = true
insert_final_newline = true

[*.py]
max_line_length = 100

[*.{yaml,yml,toml,json}]
indent_size = 2
max_line_length = 120

[*.{md,rst,txt}]
max_line_length = 120

[Makefile]
indent_style = tab

[*.{do,R}]
indent_size = 4
